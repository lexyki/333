n = int(input("Введіть число n: "))

# --- Цикл for: вивід чисел від 1 до n ---
print("Числа від 1 до", n, ":")
for i in range(1, n + 1):
    print(i, end=" ")
print()  # перехід на новий рядок

# --- Цикл while: сума чисел від 1 до n ---
total = 0
counter = 1
while counter <= n:
    total += counter
    counter += 1

print(f"Сума чисел від 1 до {n} = {total}")
